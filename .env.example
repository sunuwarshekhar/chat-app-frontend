# Backend API base URL. Leave unset in dev to use same origin + Vite proxy (recommended).
# Set when backend is on another host (e.g. separate ngrok tunnel for backend).
# VITE_API_URL=http://localhost:3000

# WebSocket (Socket.IO) URL. Leave unset to use current page origin (so on phone via ngrok, use the ngrok URL automatically).
# Set only when backend is on a different host than the one serving the frontend.
# VITE_WS_URL=http://localhost:3000

# Optional TURN server — needed when caller and callee are on different networks (e.g. phone + desktop).
# Get credentials at https://www.metered.ca/stun-turn (free tier), then set:
# VITE_TURN_URL=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:80?transport=tcp,...
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential
# If calls still fail with TURN, try STUN-only (e.g. same WiFi): VITE_TURN_DISABLE=1
